{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "~/",
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "/mnt/c/Users/wawo"
      ],
      "allowRead": [
        "."
      ],
      "allowWrite": []
    },
    "network": {
      "allowedDomains": [],
      "deniedDomains": []
    },
    "excludedCommands": []
  },
  "permissions": {
    "deny": [
      "Read(//home/wawo/**)",
      "Read(//mnt/c/Users/wawo/.ssh/**)",
      "Read(//mnt/c/Users/wawo/.aws/**)",
      "Read(//mnt/c/Users/wawo/.config/gcloud/**)",
      "Edit(//home/wawo/**)",
      "Edit(//mnt/c/Users/wawo/.ssh/**)"
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  }
}
